# ============================================
# WOCS .env.example
# 새 환경에서 이 파일을 .env로 복사 후 값 입력
# cp .env.example .env
# ============================================

# Cloudinary — https://console.cloudinary.com/settings
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# n8n — https://wocs.app.n8n.cloud → Settings → API
N8N_URL=https://wocs.app.n8n.cloud
N8N_API_KEY=

# Anthropic (Claude) — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# LinkedIn — https://developer.linkedin.com/apps
LI_CLIENT_ID=
LI_CLIENT_SECRET=

# Meta (Instagram) — https://developers.facebook.com/apps
META_APP_ID=
META_ACCESS_TOKEN=

# Aligo SMS — https://smartsms.aligo.in → API 설정
ALIGO_API_KEY=
ALIGO_USER_ID=

# Google Drive — https://drive.google.com 폴더 URL에서 ID 추출
GOOGLE_DRIVE_FOLDER_ID=

# WordPress — wp-admin → 사용자 → 앱 비밀번호 생성
WP_URL=https://glampingtentgo.com
WP_USER=
WP_APP_PASSWORD=

# Gemini (Google AI Studio) — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenAI (ChatGPT) — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# YouTube (Google Cloud) — https://console.cloud.google.com/apis/credentials
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# Perplexity — https://perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# Canva — https://www.canva.com/developers
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=

# n8n MCP — https://wocs.app.n8n.cloud → Settings → MCP → 액세스 토큰
N8N_MCP_TOKEN=발급필요_n8n_Settings_MCP_액세스토큰
